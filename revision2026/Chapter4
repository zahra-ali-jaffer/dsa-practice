//Abstract Classes -> Foster reuse, Improved modularisation
//Implementing Set -> ArraySet, LinkedSet, HashSet, TreeSet

//An abstract class can be used, because not all methods require the knowledge of how its implemented.

//addAll() method in Set -> in an abstract class
public boolean addAll(SetADT<T>A) { //Allows any type of set to be used here
  boolean isModified = false;

  for (T element : A) {
    if (this.add(element)) //Important
      isModified = true;
  }
  return isModified;
}

