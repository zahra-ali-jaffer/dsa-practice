//Implementing ADTs with Linked Structures
//Stack -> LIFO -> Linear (keep reference to top, and count)

public class LinkedStack<T> implements StackADT<T> {
	private LinearNode<T> top;
	private int count;

	/* ..., emitting constructors */

	public void push(T element) {
		LinearNode<T> temp = new LinearNode<T>(element);
		temp.setNext(top);
		top = temp;
		count++;
	}

	public T pop() {
		if (isEmpty()) throw new IllegalStateException("pop: stack empty");

		T result = top.getElement();
		top = top.getNext(); // Replaces old top with new top
		count--;

		return result;
	}

	public T peek() {
		if (isEmpty()) throw new IllegalStateException("peek: stack empty");
		return top.getElement(); 
	}

	public boolean isEmpty() { return count == 0; }
	public int size() { return count; }
}

//push(), pop(), and peek() all occur in O(1)
//If bounded stack needed, Use Arrays

//Queue -> FIFO -> Linear (final node in queue's next set to null, keep track of front, rear and count)
//Count makes size() more efficient (O(n) → O(1))

public LinkedQueue<T> implements QueueADT<T> {
	private int count;
	private LinearNode<T> front;
	private LinearNode<T> rear; // To make enqueue() faster.

	public LinkedQueue() {
		count = 0;
		front = null;
		rear = null;
	}

	public void enqueue(T element) {
		LinearNode<T> node = new LinearNode<T>(element);
		if (isEmpty()) front = node;
		else {
			rear.setNext(node);
			rear = node;
			count++;
		}
	}

	public T dequeue() {
		if (isEmpty()) throw new IllegalStateException("dequeue: queue empty!");

		T result = front.getElement();
		front = front.getNext();
		count--;

		// Check, else  enqueue after the linked node, not updating the front
		if (isEmpty()) rear = null; 

		return result;
	}

	public boolean isEmpty() { return front == null; }
	public int size() { return count; }
	public void clear() { front = null; rear = null; count = 0; }
}

